<?xml version="1.0" encoding="utf-8"?>
<RevitAddIns>
  <AddIn Type="Application">
    <Name>PluginName</Name>
    <!-- DLL はサブフォルダ PluginName\ に配置されます -->
    <Assembly>PluginName\PluginName.dll</Assembly>
    <FullClassName>PluginName.App</FullClassName>
    <ClientId>REPLACE-WITH-NEW-GUID</ClientId>
    <VendorId>YourCompany</VendorId>
    <VendorDescription>Your Company Name</VendorDescription>
  </AddIn>
</RevitAddIns>
